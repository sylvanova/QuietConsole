msgid "Quiet Console"
msgstr "Consola silenciosa"

msgid "Start consoles in quiet mode"
msgstr "Iniciar las consolas en modo silencioso"

msgid "Log suppressed events (for debugging)"
msgstr "Registrar eventos suprimidos (depuración)"

msgid "Extreme suppression mode (aggressive)"
msgstr "Modo de supresión extrema (agresivo)"

msgid "Toggle quiet console mode for this terminal window."
msgstr "Alternar el modo consola silenciosa para esta terminal."

msgid "Toggle live plain text view for this terminal window."
msgstr "Alternar vista de texto plano en vivo para esta terminal."

msgid "Focus a supported console window first."
msgstr "Enfoca primero una ventana de consola compatible."

msgid "enabled"
msgstr "activado"

msgid "disabled"
msgstr "desactivado"

msgid "Quiet console mode {state}."
msgstr "Modo consola silenciosa {state}."

msgid "Quiet Console - Live Plain Text"
msgstr "Consola silenciosa - Texto plano en vivo"

msgid "Follow bottom"
msgstr "Seguir al final"

msgid "Fixed line"
msgstr "Línea fija"

msgid "Plain text view opened."
msgstr "Vista de texto plano abierta."

msgid "Plain text view closed."
msgstr "Vista de texto plano cerrada."

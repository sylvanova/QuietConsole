msgid "Quiet Console"
msgstr "Console silencioso"

msgid "Start consoles in quiet mode"
msgstr "Iniciar consoles em modo silencioso"

msgid "Log suppressed events (for debugging)"
msgstr "Registrar eventos suprimidos (depuração)"

msgid "Extreme suppression mode (aggressive)"
msgstr "Modo de supressão extrema (agressivo)"

msgid "Toggle quiet console mode for this terminal window."
msgstr "Alternar o modo console silencioso para esta janela."

msgid "Toggle live plain text view for this terminal window."
msgstr "Alternar visualização de texto simples em tempo real para esta consola."

msgid "Focus a supported console window first."
msgstr "Coloque primeiro o foco numa janela de consola suportada."

msgid "enabled"
msgstr "ativado"

msgid "disabled"
msgstr "desativado"

msgid "Quiet console mode {state}."
msgstr "Modo consola silenciosa {state}."

msgid "Quiet Console - Live Plain Text"
msgstr "Console silencioso - Texto simples em tempo real"

msgid "Follow bottom"
msgstr "Seguir o final"

msgid "Fixed line"
msgstr "Linha fixa"

msgid "Plain text view opened."
msgstr "Vista de texto simples aberta."

msgid "Plain text view closed."
msgstr "Vista de texto simples fechada."

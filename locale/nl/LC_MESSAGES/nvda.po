msgstr "ingeschakeld"

msgid "disabled"
msgstr "uitgeschakeld"

msgid "Quiet console mode {state}."
msgstr "Stille consolemodus {state}."

msgid "Quiet Console - Live Plain Text"
msgstr "Stille console - Live platte tekst"

msgid "Follow bottom"
msgstr "Onderkant volgen"

msgid "Fixed line"
msgstr "Vaste regel"

msgid "Plain text view opened."
msgstr "Platte-tekstweergave geopend."

msgid "Plain text view closed."
msgstr "Platte-tekstweergave gesloten."

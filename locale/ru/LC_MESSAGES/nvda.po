msgid "Quiet Console"
msgstr "Тихая консоль"

msgid "Start consoles in quiet mode"
msgstr "Запускать консоль в тихом режиме"

msgid "Log suppressed events (for debugging)"
msgstr "Логировать подавленные события (отладка)"

msgid "Extreme suppression mode (aggressive)"
msgstr "Экстремальное подавление (агрессивно)"

msgid "Toggle quiet console mode for this terminal window."
msgstr "Переключить тихий режим для этого терминала."

msgid "Toggle live plain text view for this terminal window."
msgstr "Переключить живой просмотр простого текста для этого терминала."

msgid "Focus a supported console window first."
msgstr "Сначала сфокусируйте поддерживаемое окно консоли."

msgid "enabled"
msgstr "включено"

msgid "disabled"
msgstr "выключено"

msgid "Quiet console mode {state}."
msgstr "Тихий режим консоли {state}."

msgid "Quiet Console - Live Plain Text"
msgstr "Тихая консоль - Живой простой текст"

msgid "Follow bottom"
msgstr "Следовать за концом"

msgid "Fixed line"
msgstr "Фиксированная строка"

msgid "Plain text view opened."
msgstr "Открыт просмотр простого текста."

msgid "Plain text view closed."
msgstr "Просмотр простого текста закрыт."

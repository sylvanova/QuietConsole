msgstr "Project-Id-Version: QuietConsole\nLanguage: it\nMIME-Version: 1.0\nContent-Type: text/plain; charset=UTF-8\nContent-Transfer-Encoding: 8bit\n"

msgid "Quiet Console"
msgstr "Console silenziosa"

msgid "Start consoles in quiet mode"
msgstr "Avvia le console in modalità silenziosa"

msgid "Log suppressed events (for debugging)"
msgstr "Registra eventi soppressi (debug)"

msgid "Extreme suppression mode (aggressive)"
msgstr "Modalità di soppressione estrema (aggressiva)"

msgid "Toggle quiet console mode for this terminal window."
msgstr "Attiva/disattiva la modalità console silenziosa per questo terminale."

msgid "Toggle live plain text view for this terminal window."
msgstr "Attiva/disattiva la vista testo semplice in tempo reale per questo terminale."

msgid "Focus a supported console window first."
msgstr "Metti prima il focus su una finestra console supportata."

msgid "enabled"
msgstr "abilitato"

msgid "disabled"
msgstr "disabilitato"

msgid "Quiet console mode {state}."
msgstr "Modalità console silenziosa {state}."

msgid "Quiet Console - Live Plain Text"
msgstr "Console silenziosa - Testo semplice in tempo reale"

msgid "Follow bottom"
msgstr "Segui il fondo"

msgid "Fixed line"
msgstr "Riga fissa"

msgid "Plain text view opened."
msgstr "Vista testo semplice aperta."

msgid "Plain text view closed."
msgstr "Vista testo semplice chiusa."
